# NoxPay Environment Variables Example

# ==========================================
# Dashboard Security
# ==========================================
# The global password required to access the dashboard. 
# Keep this secure.
AUTH_PASSWORD="your_super_secret_dashboard_password"

# ==========================================
# Database (Supabase)
# ==========================================
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_KEY="your-anon-or-service-role-key"

# ==========================================
# API Keys & Secrets
# ==========================================
# Master API Key for dashboard -> API communication
MASTER_API_KEY="your_secure_randomly_generated_master_key"

# Allowed CORS origins for the API (comma-separated)
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# ==========================================
# Worker Configuration (if applicable)
# ==========================================
# Add any worker-specific env vars here
